{
  "organization": "acme",
  "defaults": {
    "region": "westeurope",
    "replicas": 2,
    "cpu": "250m",
    "memory": "512Mi",
    "namespacePattern": "{app}-{env}"
  },
  "runtime": {
    "name": "kubernetes",
    "config": {
      "namespacePattern": "{app}-{env}"
    }
  },
  "provisionerConfigs": {
    "pulumi": {
      "projectDir": "./infra"
    }
  },
  "provisioners": {
    "postgres": "pulumi",
    "redis": "pulumi",
    "kafka.messaging": "pulumi"
  },
  "policies": {
    "allowedRegions": ["westeurope", "northeurope", "eastus2"],
    "enforceTLS": true
  }
}
